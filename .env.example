GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# OR set GOOGLE_SERVICE_ACCOUNT_JSON with the full JSON content (preferred for Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# === Google Drive (source of truth for property listings) ===
# The root Drive folder ID containing property subfolders.
# Overrides config.yaml: google_drive.listings_folder_id
GOOGLE_DRIVE_FOLDER_ID=1GXeGULYswb7jXcMGCCRm2RQ_h0EKsDll
# Legacy alias — kept for compat
# GOOGLE_DRIVE_LISTINGS_FOLDER_ID=

AI_PROVIDER=nvidia-nim
AI_MODEL=stepfun-ai/step-3.7-flash
NVIDIA_API_KEY=replace-with-nvidia-nim-key
# OPENAI_API_KEY=replace-with-openai-key
# ANTHROPIC_API_KEY=replace-with-anthropic-key

# === Supabase — local/dev template only ===
# Server-side (FastAPI backend). NEVER expose the service role key to the browser.
SUPABASE_URL=https://REPLACE-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key

# === Auth: Supabase Auth (uses email/password, seeded admin + operator accounts) ===
# Front-end Supabase credentials (safe for browser usage)
VITE_SUPABASE_URL=https://REPLACE-with-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key

# === Google sign-in domain restriction (optional) ===
# Leave BLANK to allow any Google account. Only set if restricting to a G Suite domain.
VITE_APG_GOOGLE_DOMAIN=

POSTING_TRACKER_SHEET_ID=1xzzuq8KHbzrRIGMyIo0AQVgq0LQklDkW8-S9Y__7RvM
DAILY_REPORT_DOC_ID=1mctXkKFhZLCEXQtnzO4dmHhUSGOKFdFliF_qL17U68o
