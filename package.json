{
  "name": "apg-posting-desk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web \"py -3.14 -m apg_automation.main --serve --demo --host 0.0.0.0 --port 8001\" \"vite\"",
    "dev:live": "concurrently -k -n api,web \"py -3.14 -m apg_automation.main --serve --host 0.0.0.0 --port 8001\" \"vite\"",
    "dev:api": "py -3.14 -m apg_automation.main --serve --demo --host 0.0.0.0 --port 8001",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2"
  }
}
