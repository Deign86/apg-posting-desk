rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isMaamJean() {
      return hasRole('maam_jean');
    }

    function isOperator() {
      return hasRole('user');
    }

    function canReadJobs() {
      return isAdmin() || isMaamJean() || isOperator();
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || isMaamJean());
      allow create, update, delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if canReadJobs();
      allow create: if isAdmin() || isMaamJean();
      allow update: if isAdmin() || isMaamJean() || (isOperator() && resource.data.operator_uid == request.auth.uid);
      allow delete: if isAdmin();

      match /activity/{activityId} {
        allow read: if canReadJobs();
        allow create: if isAdmin() || isMaamJean() || isOperator();
        allow update, delete: if false;
      }
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
